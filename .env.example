# Optional: some rooms return richer data when you pass your browser cookie.
# Copy this file to .env and fill in your own cookie if you need it.
DOUYIN_COOKIE=
PORT=3000
HOST=127.0.0.1
UPSTREAM_TIMEOUT_MS=10000
# Optional static upstream proxy. Node versions can use a direct HTTP(S) proxy like http://127.0.0.1:7890
# or a reverse-proxy template such as https://proxy.example.com/fetch?url={url}
UPSTREAM_PROXY_URL=
# Optional: if set, /api/room requires X-API-Key or Authorization: Bearer <key>
API_KEY=
