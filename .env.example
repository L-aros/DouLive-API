# Optional: some rooms return richer data when you pass your browser cookie.
# Copy this file to .env and fill in your own cookie if you need it.
DOUYIN_COOKIE=
PORT=3000
HOST=127.0.0.1
UPSTREAM_TIMEOUT_MS=10000
# Optional static upstream proxy.
# Supported formats (Node/Vercel):
#   http://ip:port
#   http://user:pass@ip:port
#   ip:port:user:pass  (shorthand, auto-parsed)
#   https://proxy.example.com/fetch?url={url}  (reverse-proxy template)
# Cloudflare Workers only supports reverse-proxy template format.
UPSTREAM_PROXY_URL=
# Optional: if set, /api/room requires X-API-Key or Authorization: Bearer <key>
API_KEY=
